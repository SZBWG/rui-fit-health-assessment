{
  "name": "health-assessment-funnel",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=22.13.0"
  },
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "prisma generate && next build",
    "start": "next start",
    "lint": "eslint . --ignore-pattern .next --ignore-pattern app/generated",
    "typecheck": "tsc --noEmit",
    "test": "node --env-file-if-exists=.env scripts/test.mjs",
    "test:unit": "vitest run tests/unit",
    "test:coverage": "node --env-file-if-exists=.env scripts/test.mjs --coverage",
    "test:e2e": "playwright test",
    "verify": "npm run lint && npm run typecheck && npm run test:coverage && npm run build && npm run test:e2e",
    "db:dev": "prisma dev --name health-quiz --detach",
    "db:reset": "node --env-file-if-exists=.env scripts/reset-db.mjs",
    "db:deploy": "prisma migrate deploy",
    "db:seed": "tsx prisma/seed.ts",
    "setup": "npm run db:dev && npm run db:reset && npm run db:seed",
    "postinstall": "prisma generate"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "dotenv": "^17.4.2",
    "next": "^16.2.10",
    "pg": "^8.22.0",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@tailwindcss/postcss": "4.2.1",
    "@types/node": "22.19.19",
    "@types/pg": "^8.20.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitest/coverage-v8": "^4.1.10",
    "eslint": "9.39.4",
    "eslint-config-next": "^16.2.10",
    "prisma": "^7.8.0",
    "tailwindcss": "4.2.1",
    "tsx": "^4.23.1",
    "typescript": "5.9.3",
    "vitest": "^4.1.10"
  },
  "overrides": {
    "@hono/node-server": "1.19.13",
    "postcss": "8.5.10"
  },
  "type": "module"
}
